#!/bin/zsh
# explainer2 CLI wrapper — runs the vendored pipeline with the shared media venv
# (~/myenv holds the verified torch/Kokoro/Playwright stack; see pyproject.toml).
# No install into the venv needed, and zero risk to the production v1 console script.
